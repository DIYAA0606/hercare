{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    },
    {
      "src": "herbalance/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],

  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "app.py"
    },

    {
      "src": "/(.*)",
      "dest": "/herbalance/$1"
    }
  ]
}